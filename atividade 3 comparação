
class produtos():
    def __init__(self, nome, preco):
        self.nome = nome
        self.preco = preco

    def __gt__(self, outro):
        return self.preco > outro.preco

    def __eq__ (self, outro):
        return self.preco == outro.preco

p1 = produtos( "carro", 5000.00 )
p2 = produtos("moto", 2000.00)

print(p1 > p2)
    
print(p1 == p2)
